# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Local build artifacts (Go binaries built in repo root)
/dashboard
/component-monitor
/mock-monitored-component
/mock-oauth-proxy

/ship-status-dev-logs/

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.out
coverage.html
coverage.xml
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
.idea/
.vscode/

# Cursor local commands
.cursor/commands/local/


# APM dependencies
apm_modules/

# MCP server virtualenv
mcp/.venv/
